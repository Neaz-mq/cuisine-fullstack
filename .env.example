# Copy this file to .env (or .env.local) and fill in real values.
# Never commit the actual .env file — it's already in .gitignore.

# ---------------------------------------------------------------------------
# Database (Postgres via Prisma) — required
# ---------------------------------------------------------------------------
# Pooled connection string, used by the app at runtime.
DATABASE_URL="postgresql://user:password@host:5432/cuisine?pgbouncer=true"
# Direct (non-pooled) connection string, used by Prisma CLI for migrations
# and by prisma.config.ts. With most providers (Supabase, Neon, etc.) this
# is the same host on a different port/without the pooler flag.
DIRECT_URL="postgresql://user:password@host:5432/cuisine"

# ---------------------------------------------------------------------------
# Auth (NextAuth v5) — required
# ---------------------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Google OAuth — required only if you want "Sign in with Google" to work.
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# App URL — required
# ---------------------------------------------------------------------------
# Used for building absolute links in emails, Stripe redirect URLs, etc.
# Set to your real domain in production (e.g. https://cuisine.example.com).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Stripe — required for online payment / checkout
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# locally, or the webhook's signing secret in the Stripe Dashboard in prod.
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---------------------------------------------------------------------------
# Supabase — required (used for image storage, e.g. menu item photos)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only secret key — never expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY="sb_secret_..."

# ---------------------------------------------------------------------------
# Resend — required for transactional/marketing email
# ---------------------------------------------------------------------------
RESEND_API_KEY="re_..."
# Sender shown on order confirmation / gift card emails, e.g.
# "Cuisine <orders@yourdomain.com>". The domain must be verified in Resend.
EMAIL_FROM="Cuisine <orders@yourdomain.com>"
# Optional — falls back to EMAIL_FROM if not set. Only needed if marketing
# broadcasts should come from a different sender than order emails.
MARKETING_EMAIL_FROM=""
# Optional — only needed by the admin marketing-broadcast feature, which
# syncs customers into a Resend Audience. Create an Audience in the Resend
# dashboard and copy its ID here.
RESEND_AUDIENCE_ID=""
