// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Persisted marketing preference for logged-in customers — lets us
  // prefill the checkout consent checkbox on their next order, and is
  // what the /admin/marketing "audience size" count is based on.
  // NOT the source of truth for guest checkout consent — see
  // Order.marketingConsent below for that.
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime? // when they last changed it — useful for
  // proving consent timing if ever disputed

  // Running balance, kept in sync with LoyaltyTransaction rows inside the
  // same DB transaction whenever it changes (order delivered, manual admin
  // adjustment). Denormalized on purpose — displaying points for a user list
  // shouldn't require summing the whole ledger on every page view.
  loyaltyPoints Int @default(0)

  orders              Order[]
  reservations        Reservation[]
  reviews             Review[]
  loyaltyTransactions LoyaltyTransaction[]

  // Present only for staff accounts (role != CUSTOMER). A CUSTOMER user
  // never has one of these — the Staff management feature is what creates
  // both the User row and this row together, in one transaction.
  staffProfile StaffProfile?

  // Present only for Role.DELIVERY staff — every order this person has
  // ever been assigned to ride out. A rider "logs in" with the exact same
  // credentials login every other staff role uses; there is no separate
  // rider auth system.
  deliveries DeliveryTracking[] @relation("RiderDeliveries")
}

// CUSTOMER is the only non-staff role. Every other value is a "staff role"
// (see lib/permissions.ts:isStaffRole) and gets a StaffProfile row.
//
// Renamed from the old two-value { CUSTOMER, ADMIN } enum: ADMIN -> OWNER
// (full, unrestricted access — same as ADMIN used to mean), plus five new
// narrower staff roles so day-to-day staff (waiters, kitchen, etc.) don't
// need full admin access just to do their job.
enum Role {
  CUSTOMER
  OWNER
  MANAGER
  WAITER
  CASHIER
  DELIVERY
  KITCHEN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

// One row per staff User (role != CUSTOMER), created together with the User
// row when an OWNER/MANAGER adds a new staff member via /admin/staff.
model StaffProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Human-facing sequential ID shown in the Staff UI (e.g. "EMP-0007") —
  // friendlier to read/say out loud than the cuid in `userId`.
  employeeId     String         @unique
  department     String?
  employmentType EmploymentType @default(FULL_TIME)
  phone          String?
  hireDate       DateTime       @default(now())

  // Deactivating a staff member (instead of deleting) keeps their name on
  // historical orders/audit trails intact, while blocking further login.
  isActive       Boolean        @default(true)

  // Sensitive fields — only ever read or written by OWNER-role requests.
  // MANAGER can see/edit everything else on this model but not these two.
  nid            String?
  salary         Float?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  menuItems MenuItem[]

  // Coupons restricted to "only this category" — see the restriction note
  // on Coupon below. Most categories will have zero linked coupons; this
  // is not the common case, just an available rule.
  restrictedByCoupons Coupon[] @relation("CouponCategories")
}

model MenuItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  category   Category    @relation(fields: [categoryId], references: [id])
  categoryId String
  orderItems OrderItem[]
  reviews    Review[]

  // Coupons restricted to "only this item" — see the restriction note on
  // Coupon below.
  restrictedByCoupons Coupon[] @relation("CouponItems")
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PLACED)
  totalAmount Float

  // DELIVERY (default) = existing checkout flow, unchanged. DINE_IN = QR
  // Table Ordering — customer scans a QR code at a physical table, orders
  // are tied to `table` below instead of a delivery address, and are paid
  // for at the table (see paymentMethod note below), not delivered.
  orderType OrderType @default(DELIVERY)

  // Billing / contact details captured at checkout.
  //
  // firstName/lastName/phone stay REQUIRED for both order types — staff
  // still need a name to call out at the table for DINE_IN orders.
  //
  // email/country/address/city/state/zip are OPTIONAL as of QR Table
  // Ordering: a DINE_IN order has no delivery destination, so these are
  // simply never collected/set for orderType = DINE_IN. They remain
  // required in practice (application-layer validation) for
  // orderType = DELIVERY — this is intentionally not enforced at the DB
  // level, since Prisma/Postgres can't express "required if X" directly.
  email     String?
  firstName String
  lastName  String
  phone     String
  country   String?
  address   String?
  apartment String?
  city      String?
  state     String?
  zip       String?

  // OPTIONAL as of QR Table Ordering — irrelevant for orderType = DINE_IN
  // (nothing is being shipped). Still required in practice for DELIVERY
  // orders, enforced at the application layer.
  shippingMethod ShippingMethod?

  // For orderType = DINE_IN, this is always COD — reused deliberately
  // rather than adding a third enum value, since "pay at table" is
  // functionally identical to "pay on delivery" (staff collects payment
  // in person, no online charge). The UI labels it "Pay at Table" instead
  // of "Cash on Delivery" for DINE_IN orders, but the stored value is COD.
  paymentMethod PaymentMethod

  // Which physical table a DINE_IN order belongs to. Null for DELIVERY
  // orders. Deliberately NOT required even when orderType = DINE_IN at the
  // DB level, for the same "can't express conditional-required in Prisma"
  // reason as the billing fields above — enforced at the application layer.
  table   RestaurantTable? @relation(fields: [tableId], references: [id])
  tableId String?

  // Discount/Coupon — totalAmount above is already net of this discount
  // (i.e. it's the actual amount charged/owed). discountAmount and
  // couponCode are denormalized here purely for display (order summary,
  // confirmation email, admin order detail) without needing a join back to
  // Coupon. The authoritative "was this coupon redeemed, on which order, by
  // which customer" record lives on CouponRedemption below (see the
  // Coupon/CouponRedemption models for the full v2 design rationale).
  couponCode       String?
  discountAmount   Float             @default(0)
  couponRedemption CouponRedemption? // back-relation only — FK lives on CouponRedemption.orderId

  // Gift card redemption — same denormalized-display pattern as the
  // coupon fields above. giftCardAmount is already netted out of
  // totalAmount (the amount actually charged/owed). The authoritative
  // "which card, how much, on which order" record lives on
  // GiftCardTransaction below (type REDEEM) — giftCardCode/giftCardAmount
  // here exist purely so the order summary, confirmation email, and admin
  // order detail can show "Gift card XXXX applied — $12.00" without a
  // join back to GiftCard. A single order can only ever redeem ONE gift
  // card (matches the checkout UI, one code field at a time), same
  // simplification as couponCode being a single nullable field.
  giftCardCode         String?
  giftCardAmount       Float                 @default(0)
  giftCardTransactions GiftCardTransaction[]

  // Guards against re-crediting loyalty points if an order is moved to
  // DELIVERED, reverted, and marked DELIVERED again by mistake.
  pointsAwarded Boolean @default(false)

  // Tracks real payment confirmation for ONLINE orders via Stripe Checkout
  // + webhook — separate from `status` (fulfillment stage) because an order
  // can be PLACED in our DB before Stripe has actually confirmed the charge.
  // For COD orders (and DINE_IN, which is always COD) this is left at its
  // default and isn't currently acted on anywhere (no "mark paid on
  // delivery/at table" admin action exists yet).
  paymentStatus PaymentStatus @default(PENDING)

  // Captured at checkout, independent of User.marketingConsent, because
  // guest checkout (userId = null) has no User row to store a preference
  // on. This is what the checkout.session.completed webhook (and the COD
  // order-creation path) checks before calling syncCustomerToAudience().
  marketingConsent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Guest checkout is allowed, matching /carts which isn't behind auth
  user   User?  @relation(fields: [userId], references: [id])
  userId String?

  items               OrderItem[]
  loyaltyTransactions LoyaltyTransaction[]

  // One-to-one — only present once a rider has been assigned (see
  // POST /api/admin/orders/[id]/assign-rider). Null for DINE_IN orders and
  // for DELIVERY orders still using UBER_EATS/FOOD_PANDA.
  deliveryTracking DeliveryTracking?

  // tableId: DINE_IN orders looked up by table (unchanged, pre-existing).
  //
  // userId + createdAt: GET /api/orders/mine does `WHERE userId = ?
  // ORDER BY createdAt DESC` — every logged-in customer's order-history
  // page hits this exact pattern. Without it, that's a full table scan
  // once Order grows past a few hundred rows.
  //
  // status: the Kitchen board (GET /api/admin/kitchen/orders) polls this
  // table every 15s (see ETA_POLL_INTERVAL_MS) filtering `status IN
  // (PLACED, PREPARING)` — the single hottest read in the app. Also used
  // by the admin Orders list's status filter.
  //
  // createdAt (alone): the admin Orders list's default view — no status
  // filter, sorted newest-first — needs its own index since the
  // [userId, createdAt] composite above can't serve a query with no
  // userId predicate.
  @@index([tableId])
  @@index([userId, createdAt])
  @@index([status])
  @@index([createdAt])
}

enum OrderType {
  DELIVERY
  DINE_IN
}

enum OrderStatus {
  PLACED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum ShippingMethod {
  UBER_EATS
  FOOD_PANDA
  // Restaurant's own delivery staff (Role.DELIVERY) — the rider is a real
  // staff account, assigned to the order from /admin/orders/[id], and
  // shares their live GPS position via the DeliveryTracking row below so
  // the customer's /track/[orderId] page can show a live map, the same
  // customer-facing pattern as Uber Eats / Food Panda's own apps.
  OWN_DELIVERY
}

enum PaymentMethod {
  COD
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

// Live rider tracking for OWN_DELIVERY orders. One row per order, created
// the moment an admin assigns a rider (POST
// /api/admin/orders/[id]/assign-rider) and never re-created after that —
// only ever updated (rider's phone posts new lat/lng every few seconds
// while /admin/my-deliveries is open, see POST
// /api/rider/deliveries/[orderId]/location).
//
// destLat/destLng are geocoded once at assignment time from the order's
// existing address fields (see lib/geocode.ts) — re-geocoding on every
// customer poll would be wasteful and Nominatim's free tier is rate
// limited. riderLat/riderLng start out equal to the destination as a
// harmless default until the rider's browser reports its first real
// position.
model DeliveryTracking {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  riderId String
  rider   User   @relation("RiderDeliveries", fields: [riderId], references: [id])

  riderLat Float
  riderLng Float
  // When riderLat/riderLng were last updated — the customer-facing map
  // uses this to show "updated Xs ago" and to detect a rider who has gone
  // quiet (tab closed / phone locked, since this is browser-based tracking
  // rather than a native background-GPS app).
  riderLocationUpdatedAt DateTime @default(now())

  destLat Float
  destLng Float

  assignedAt  DateTime  @default(now())
  deliveredAt DateTime?

  @@index([riderId])
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float

  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
}

// ---------------------------------------------------------------------------
// Discount coupons — v2, market-standard rule engine
//
// Supersedes the v1 "percentage-off, single global use" design. A coupon
// now carries a full set of independently-optional eligibility rules —
// discount type (percent or fixed), an expiry window, a minimum order
// value, a cap on how much a percent coupon can discount, a total
// redemption cap, and a per-customer redemption cap. Every rule is
// optional (null = "no restriction on this axis") so a simple "10% off,
// forever, unlimited" coupon is still just as easy to create as before.
//
// usageCount is a denormalized, atomically-incremented counter (see
// consumeCoupon in order-checkout-shared.ts) — it's the fast/cheap check
// for "has the global cap been hit" without a COUNT(*) over
// CouponRedemption on every checkout. CouponRedemption itself is the
// authoritative, queryable audit log: one row per successful redemption,
// carrying which order, which customer, and exactly how much discount was
// granted — needed both for per-customer limit enforcement and for
// usage analytics (a hard-deleted Coupon row would otherwise take that
// history down with it).
//
// isActive is independent of the usage counters — it's a manual
// admin kill-switch (pull a code immediately, e.g. a typo or abuse),
// separate from the coupon naturally running out via usageLimit or
// expiresAt.
// ---------------------------------------------------------------------------
model Coupon {
  id   String             @id @default(cuid())
  code String             @unique
  type CouponDiscountType @default(PERCENT)

  // Exactly one of these is meaningful, matching `type` — enforced at the
  // application layer (see validateCouponInput in order-checkout-shared.ts),
  // not at the DB level, since Prisma can't express a conditional-required
  // column directly.
  percentOff Int? // 1-100, required when type = PERCENT
  fixedOff   Float? // currency amount, required when type = FIXED

  // Optional cap on the computed discount amount — mainly guards PERCENT
  // coupons from granting an unexpectedly large discount on a big order
  // (e.g. "20% off, capped at $15"). Ignored for FIXED coupons, since a
  // fixed amount is already its own cap.
  maxDiscountAmount Float?

  // Optional minimum subtotal required to redeem (e.g. "min order $20").
  minOrderValue Float?

  // Optional redemption window. Both null = no time restriction. A coupon
  // with only startsAt set isn't redeemable before that instant; only
  // expiresAt set isn't redeemable after it.
  startsAt  DateTime?
  expiresAt DateTime?

  // Optional global usage cap across ALL customers combined (e.g. "first
  // 100 redemptions"). Null = unlimited. usageCount is the atomically
  // incremented counter checked against this cap at redemption time.
  usageLimit Int?
  usageCount Int  @default(0)

  // Optional per-customer cap (e.g. "one use per customer"). Null =
  // unlimited per customer. Defaults to 1, matching the most common
  // real-world "one redemption per person" coupon. Enforced by counting
  // that customer's CouponRedemption rows for this coupon — see
  // consumeCoupon's inline comment for the concurrency caveat on this
  // specific check.
  perCustomerLimit Int? @default(1)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions CouponRedemption[]

  // Optional item/category scoping — both empty (the default) means "no
  // restriction, applies to the whole cart," matching every coupon's
  // behavior before this field existed (TEST10, SAVE5, etc. keep working
  // unchanged). When either is non-empty, the coupon is only redeemable
  // if the cart contains at least one matching line, and the discount is
  // computed against ONLY the matching lines' subtotal — not the whole
  // cart — see calcDiscountAmount/findValidCoupon in
  // order-checkout-shared.ts. minOrderValue above still checks the FULL
  // cart subtotal regardless of this scoping (a deliberate choice: "spend
  // $15 total, get $5 off the pizzas in that order" rather than "spend
  // $15 on pizzas specifically").
  restrictedCategories Category[] @relation("CouponCategories")
  restrictedItems      MenuItem[] @relation("CouponItems")

  @@index([isActive])
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

// One row per successful redemption — the audit trail a hard single-use
// flag on Coupon could never provide, and the source of truth for
// per-customer limit enforcement (findValidCoupon/consumeCoupon count a
// customer's rows here, scoped to one coupon, rather than trusting a
// boolean).
model CouponRedemption {
  id       String @id @default(cuid())
  coupon   Coupon @relation(fields: [couponId], references: [id])
  couponId String

  // One redemption per order, enforced by the @unique below — an order
  // can only ever have consumed one coupon (matches Order.couponCode
  // being a single nullable field, not a list).
  order   Order  @relation(fields: [orderId], references: [id])
  orderId String @unique

  // Identifies "who" redeemed this for per-customer-limit purposes: the
  // logged-in User.id when available, otherwise the normalized phone
  // number from billing (guest checkout is allowed — see Order.userId).
  // Not a foreign key on purpose, since a guest has no User row at all.
  customerKey String

  // The actual discount amount granted on this specific order — kept here
  // (in addition to the denormalized Order.discountAmount) so redemption
  // history/analytics survive independently of the Order row's own
  // display fields, and so "how much did this coupon cost us in total"
  // is a simple SUM(discountAmount) over one coupon's redemptions.
  discountAmount Float

  createdAt DateTime @default(now())

  @@index([couponId, customerKey])
}

// ---------------------------------------------------------------------------
// Table reservations
//
// Design note: a table is NOT a static booked/free flag. Real restaurants
// reuse the same table across different time slots in a day, so "booked"
// only makes sense relative to a specific date/time window. Availability is
// computed at query time in the API layer by checking for overlapping
// Reservation rows for that table, not stored as a boolean on RestaurantTable.
// ---------------------------------------------------------------------------
model RestaurantTable {
  id        String   @id @default(cuid())
  label     String   @unique
  capacity  Int      @default(4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  reservations Reservation[]
  // QR Table Ordering — DINE_IN orders placed against this table (see
  // Order.tableId above). A table with isActive = false should have its QR
  // code treated as invalid by the ordering flow, not just hidden from the
  // reservation picker.
  orders       Order[]
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(cuid())
  customerName String
  phone        String
  guestCount   Int
  reservedAt   DateTime
  status       ReservationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  table   RestaurantTable @relation(fields: [tableId], references: [id])
  tableId String

  // Optional: reservations don't require login (matches the current /table
  // page, which isn't behind auth), but we link the account when available.
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([tableId, reservedAt])
}

// ---------------------------------------------------------------------------
// Restaurant settings
//
// Single-row table pattern — সবসময় ঠিক একটাই row থাকবে (id: "singleton")।
// আগে TopBar.tsx-এ timezone আর kitchen open/close hour hardcoded const
// হিসেবে ছিল (কোড এডিট করে redeploy করতে হতো)। এখন এটা admin panel
// (/admin/settings) থেকে UI দিয়েই পরিবর্তনযোগ্য।
// ---------------------------------------------------------------------------
model RestaurantSettings {
  id               String   @id @default("singleton")
  timezone         String   @default("Asia/Dhaka")
  kitchenOpenHour  Int      @default(10)
  kitchenCloseHour Int      @default(22)
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Reviews & Ratings
//
// Design note: verified-purchase eligibility (user must have a DELIVERED
// order containing this menuItem) is enforced in API logic, not as a schema
// constraint — same query-time-computation pattern used for
// RestaurantTable availability above, rather than denormalizing purchase
// state onto this model.
//
// One review per (user, menuItem) — @@unique below. Re-reviewing the same
// item after a repeat order is an UPDATE to the existing review, not a new
// row.
//
// avgRating/reviewCount are intentionally NOT cached on MenuItem; they are
// computed on read via aggregate query. Can be denormalized later purely as
// a perf optimization if needed — not a correctness requirement now.
// ---------------------------------------------------------------------------
model Review {
  id        String       @id @default(cuid())
  rating    Int
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String

  @@unique([userId, menuItemId])
  @@index([menuItemId, status])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Loyalty / Rewards Points
//
// Ledger + cached balance pattern: every change to a user's points (an
// order getting DELIVERED, or an admin's manual adjustment) writes a
// LoyaltyTransaction row AND updates User.loyaltyPoints in the same DB
// transaction, so the running balance never drifts from its history.
//
// `points` is signed: positive = credit (earned), negative = debit
// (redeemed / manual deduction). `orderId` is optional because manual
// admin adjustments aren't tied to any specific order.
// ---------------------------------------------------------------------------
model LoyaltyTransaction {
  id        String              @id @default(cuid())
  points    Int
  reason    LoyaltyReason
  note      String?
  createdAt DateTime            @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId String?

  @@index([userId, createdAt])
}

enum LoyaltyReason {
  ORDER_DELIVERED
  MANUAL_ADJUSTMENT
}

// ---------------------------------------------------------------------------
// Gift cards
//
// A gift card is purchased by one customer (or issued manually by an
// admin — comp/refund case) and redeemed, in full or in part, against a
// future order by whoever holds the code. Unlike a Coupon (a discount
// rule, reusable up to its limits), a GiftCard carries an actual dollar
// balance that is *spent down* over one or more redemptions until it hits
// zero — closer to a prepaid debit instrument than a discount code.
//
// balance is a denormalized running total, kept in sync with
// GiftCardTransaction rows inside the same DB transaction whenever it
// changes (a purchase credits it, an order redemption debits it) — same
// ledger + cached balance pattern as User.loyaltyPoints /
// LoyaltyTransaction. GiftCardTransaction is the authoritative,
// queryable audit log a bare balance column alone could never provide.
//
// isActive is an admin kill-switch (pull a card immediately, e.g. fraud
// or a support request), independent of balance reaching zero naturally
// through redemption.
// ---------------------------------------------------------------------------
model GiftCard {
  id      String @id @default(cuid())
  code    String @unique

  // The balance still available to redeem. Starts at initialAmount and
  // only ever decreases (via REDEEM transactions) or increases (via a
  // manual admin ADJUSTMENT, e.g. a goodwill top-up) — never reset.
  initialAmount Float
  balance       Float

  // Set once a Stripe Checkout Session for purchasing this card completes
  // (see checkout.session.completed handling in
  // src/app/api/webhooks/stripe/route.ts) — null for cards an admin
  // issues manually (comp/refund case), which are credited immediately
  // with no associated payment.
  stripeSessionId String? @unique

  // Who bought/received it — captured for the delivery email and admin
  // search, not used for redemption eligibility (anyone holding a valid,
  // active, non-zero-balance code may redeem it, matching how real gift
  // cards work — no login/ownership check at redemption time).
  purchaserEmail String?
  purchaserName  String?
  recipientEmail String?
  recipientName  String?
  message        String? // optional personal note included in the delivery email

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions GiftCardTransaction[]

  @@index([isActive])
}

enum GiftCardTransactionType {
  PURCHASE   // initial credit when a customer buys the card via Stripe
  ISSUE      // initial credit when an admin manually issues the card (no payment)
  REDEEM     // debit when applied against an order — orderId is set
  ADJUSTMENT // manual admin balance correction (top-up or deduction), no orderId
}

// One row per balance-changing event — the audit trail a bare
// GiftCard.balance column alone could never provide, mirroring
// LoyaltyTransaction's ledger design. `amount` is signed: positive =
// credit (PURCHASE/ISSUE/a top-up ADJUSTMENT), negative = debit
// (REDEEM/a deduction ADJUSTMENT).
model GiftCardTransaction {
  id     String                  @id @default(cuid())
  amount Float
  type   GiftCardTransactionType
  note   String?

  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  giftCardId String

  // Set only for REDEEM — which order this redemption paid down. Optional
  // because PURCHASE/ISSUE/ADJUSTMENT aren't tied to any order.
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId String?

  createdAt DateTime @default(now())

  @@index([giftCardId, createdAt])
}