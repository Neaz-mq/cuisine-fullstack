// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Running balance, kept in sync with LoyaltyTransaction rows inside the
  // same DB transaction whenever it changes (order delivered, manual admin
  // adjustment). Denormalized on purpose — displaying points for a user list
  // shouldn't require summing the whole ledger on every page view.
  loyaltyPoints Int @default(0)

  orders              Order[]
  reservations        Reservation[]
  reviews             Review[]
  loyaltyTransactions LoyaltyTransaction[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  menuItems MenuItem[]
}

model MenuItem {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  category   Category    @relation(fields: [categoryId], references: [id])
  categoryId String
  orderItems OrderItem[]
  reviews    Review[]
}

model Order {
  id          String      @id @default(cuid())
  status      OrderStatus @default(PLACED)
  totalAmount Float

  // DELIVERY (default) = existing checkout flow, unchanged. DINE_IN = QR
  // Table Ordering — customer scans a QR code at a physical table, orders
  // are tied to `table` below instead of a delivery address, and are paid
  // for at the table (see paymentMethod note below), not delivered.
  orderType OrderType @default(DELIVERY)

  // Billing / contact details captured at checkout.
  //
  // firstName/lastName/phone stay REQUIRED for both order types — staff
  // still need a name to call out at the table for DINE_IN orders.
  //
  // email/country/address/city/state/zip are OPTIONAL as of QR Table
  // Ordering: a DINE_IN order has no delivery destination, so these are
  // simply never collected/set for orderType = DINE_IN. They remain
  // required in practice (application-layer validation) for
  // orderType = DELIVERY — this is intentionally not enforced at the DB
  // level, since Prisma/Postgres can't express "required if X" directly.
  email     String?
  firstName String
  lastName  String
  phone     String
  country   String?
  address   String?
  apartment String?
  city      String?
  state     String?
  zip       String?

  // OPTIONAL as of QR Table Ordering — irrelevant for orderType = DINE_IN
  // (nothing is being shipped). Still required in practice for DELIVERY
  // orders, enforced at the application layer.
  shippingMethod ShippingMethod?

  // For orderType = DINE_IN, this is always COD — reused deliberately
  // rather than adding a third enum value, since "pay at table" is
  // functionally identical to "pay on delivery" (staff collects payment
  // in person, no online charge). The UI labels it "Pay at Table" instead
  // of "Cash on Delivery" for DINE_IN orders, but the stored value is COD.
  paymentMethod PaymentMethod

  // Which physical table a DINE_IN order belongs to. Null for DELIVERY
  // orders. Deliberately NOT required even when orderType = DINE_IN at the
  // DB level, for the same "can't express conditional-required in Prisma"
  // reason as the billing fields above — enforced at the application layer.
  table   RestaurantTable? @relation(fields: [tableId], references: [id])
  tableId String?

  // Discount/Coupon — totalAmount above is already net of this discount
  // (i.e. it's the actual amount charged/owed). discountAmount and
  // couponCode are denormalized here purely for display (order summary,
  // confirmation email, admin order detail) without needing a join back to
  // Coupon. The authoritative "was this coupon used, and by which order"
  // record lives on Coupon.usedByOrderId below.
  couponCode     String?
  discountAmount Float   @default(0)
  coupon         Coupon? // back-relation only — FK lives on Coupon.usedByOrderId

  // Guards against re-crediting loyalty points if an order is moved to
  // DELIVERED, reverted, and marked DELIVERED again by mistake.
  pointsAwarded Boolean @default(false)

  // Tracks real payment confirmation for ONLINE orders via Stripe Checkout
  // + webhook — separate from `status` (fulfillment stage) because an order
  // can be PLACED in our DB before Stripe has actually confirmed the charge.
  // For COD orders (and DINE_IN, which is always COD) this is left at its
  // default and isn't currently acted on anywhere (no "mark paid on
  // delivery/at table" admin action exists yet).
  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Guest checkout is allowed, matching /carts which isn't behind auth
  user   User?  @relation(fields: [userId], references: [id])
  userId String?

  items               OrderItem[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([tableId])
}

enum OrderType {
  DELIVERY
  DINE_IN
}

enum OrderStatus {
  PLACED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum ShippingMethod {
  UBER_EATS
  FOOD_PANDA
}

enum PaymentMethod {
  COD
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float

  order      Order    @relation(fields: [orderId], references: [id])
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
}

// ---------------------------------------------------------------------------
// Discount coupons
//
// v1 scope (confirmed): percentage-off only, and SINGLE GLOBAL USE — once
// any order consumes a code, it's permanently spent for everyone, not
// just that customer. This is simpler than a per-customer usage ledger
// and matches how a small single-location restaurant typically hands out
// codes (e.g. one printed flyer code, one Instagram-giveaway code).
//
// usedByOrderId (not a separate "redemption" table) is the source of
// truth for "has this been used" — claimed atomically in a transaction at
// order-creation time (see consumeCoupon in order-checkout-shared.ts) so
// two customers racing to submit the same code can't both succeed.
//
// isActive is independent of usedByOrderId: it only gates an UNUSED
// coupon (lets admin pull a code before anyone redeems it, e.g. a typo).
// A used coupon can't be re-activated into being usable again — that
// would mean two orders both claiming the same single-use discount.
// ---------------------------------------------------------------------------
model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  percentOff Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  usedByOrderId String?   @unique
  usedAt        DateTime?
  order         Order?    @relation(fields: [usedByOrderId], references: [id], onDelete: SetNull)
}

// ---------------------------------------------------------------------------
// Table reservations
//
// Design note: a table is NOT a static booked/free flag. Real restaurants
// reuse the same table across different time slots in a day, so "booked"
// only makes sense relative to a specific date/time window. Availability is
// computed at query time in the API layer by checking for overlapping
// Reservation rows for that table, not stored as a boolean on RestaurantTable.
// ---------------------------------------------------------------------------
model RestaurantTable {
  id        String   @id @default(cuid())
  label     String   @unique
  capacity  Int      @default(4)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  reservations Reservation[]
  // QR Table Ordering — DINE_IN orders placed against this table (see
  // Order.tableId above). A table with isActive = false should have its QR
  // code treated as invalid by the ordering flow, not just hidden from the
  // reservation picker.
  orders       Order[]
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(cuid())
  customerName String
  phone        String
  guestCount   Int
  reservedAt   DateTime
  status       ReservationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  table   RestaurantTable @relation(fields: [tableId], references: [id])
  tableId String

  // Optional: reservations don't require login (matches the current /table
  // page, which isn't behind auth), but we link the account when available.
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([tableId, reservedAt])
}

// ---------------------------------------------------------------------------
// Restaurant settings
//
// Single-row table pattern — সবসময় ঠিক একটাই row থাকবে (id: "singleton")।
// আগে TopBar.tsx-এ timezone আর kitchen open/close hour hardcoded const
// হিসেবে ছিল (কোড এডিট করে redeploy করতে হতো)। এখন এটা admin panel
// (/admin/settings) থেকে UI দিয়েই পরিবর্তনযোগ্য।
// ---------------------------------------------------------------------------
model RestaurantSettings {
  id               String   @id @default("singleton")
  timezone         String   @default("Asia/Dhaka")
  kitchenOpenHour  Int      @default(10)
  kitchenCloseHour Int      @default(22)
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Reviews & Ratings
//
// Design note: verified-purchase eligibility (user must have a DELIVERED
// order containing this menuItem) is enforced in API logic, not as a schema
// constraint — same query-time-computation pattern used for
// RestaurantTable availability above, rather than denormalizing purchase
// state onto this model.
//
// One review per (user, menuItem) — @@unique below. Re-reviewing the same
// item after a repeat order is an UPDATE to the existing review, not a new
// row.
//
// avgRating/reviewCount are intentionally NOT cached on MenuItem; they are
// computed on read via aggregate query. Can be denormalized later purely as
// a perf optimization if needed — not a correctness requirement now.
// ---------------------------------------------------------------------------
model Review {
  id        String       @id @default(cuid())
  rating    Int
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  menuItemId String

  @@unique([userId, menuItemId])
  @@index([menuItemId, status])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Loyalty / Rewards Points
//
// Ledger + cached balance pattern: every change to a user's points (an
// order getting DELIVERED, or an admin's manual adjustment) writes a
// LoyaltyTransaction row AND updates User.loyaltyPoints in the same DB
// transaction, so the running balance never drifts from its history.
//
// `points` is signed: positive = credit (earned), negative = debit
// (redeemed / manual deduction). `orderId` is optional because manual
// admin adjustments aren't tied to any specific order.
// ---------------------------------------------------------------------------
model LoyaltyTransaction {
  id        String              @id @default(cuid())
  points    Int
  reason    LoyaltyReason
  note      String?
  createdAt DateTime            @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId String?

  @@index([userId, createdAt])
}

enum LoyaltyReason {
  ORDER_DELIVERED
  MANUAL_ADJUSTMENT
}
